# .env.example — LINE Messaging API credentials template
# Copy this file to .env at the project root and fill in your values.
# NEVER commit your actual .env file to version control.

# LINE Messaging API Channel Access Token
# Obtain from: LINE Developers Console → Your Channel → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Recipient LINE User ID
# Obtain from: LINE Developers Console → Your Channel → Messaging API → Bot basic settings
# Or use the webhook to capture your own User ID when you send a message to the bot
LINE_USER_ID=your_line_user_id_here

# LINE Channel Secret — required for webhook signature verification (V2)
# Obtain from: LINE Developers Console → Your Channel → Basic settings → Channel secret
LINE_CHANNEL_SECRET=your_channel_secret_here

# Web Dashboard public URL (used for LINE message links)
PUBLIC_BASE_URL=https://your-render-app.onrender.com
